# LinearJC Data Registry (example)
#
# Copy to /etc/linearjc/data_registry.yaml or another location and adjust paths.
#
# Format (compact YAML for better grep-ability):
#   name: {type: fs, path: /path, kind: file|dir, protect: bool}
#   name: {type: temp, kind: file|dir}
#   name: {type: minio, bucket: bucket-name, prefix: prefix/, kind: file|dir}
#
# Register kind:
#   - file: Single file (validates archive contains exactly one file)
#   - dir: Directory with contents (extracts full structure)
#
# protect: true marks an external input as read-only for jobs.
#
# Following mainframe philosophy: explicit > implicit
# Declare what you're creating, and LinearJC validates it matches.

registry:
  # Input: Single external text file
  hello_input: {type: fs, path: /tmp/linearjc/data/hello_input.txt, kind: file, protect: true}

  # Output: Directory containing job results (hello.world creates multiple files)
  hello_output: {type: fs, path: /tmp/linearjc/data/hello_output, kind: dir}

  # Output: Directory for followup job results
  followup_output: {type: fs, path: /tmp/linearjc/data/followup_output, kind: dir}

  # Example: Chain-local temporary data
  # intermediate_data: {type: temp, kind: file}

  # Example: Permanent MinIO storage
  # permanent_artifact: {type: minio, bucket: job-artifacts, prefix: hello/artifacts/, kind: dir}

  # Example: Single file output (if job creates exactly one file)
  # report_csv: {type: fs, path: /tmp/linearjc/data/daily_report.csv, kind: file}

  # Example: Directory output with specific structure
  # website_build: {type: fs, path: /var/www/html/site, kind: dir}
